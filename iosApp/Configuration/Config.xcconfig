TEAM_ID=

PRODUCT_NAME=CitizensKMP
PRODUCT_BUNDLE_IDENTIFIER=com.tc.citizenskmp.CitizensKMP$(TEAM_ID)

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0

// Linker flags to resolve SQLite symbols and Xcode 15/16 compatibility issues
OTHER_LDFLAGS = $(inherited) -lsqlite3 -Xlinker -ld_classic -framework UIKit -framework Foundation
